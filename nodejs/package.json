    "jq-repeat": "^2.2.0",
    "jquery": "^3.7.1",
    "ldapts": "^8.1.2",
    "model-redis": "^1.6.0",
    "moment": "^2.30.1",
    "mustache": "^4.2.0",
    "redis": "^4.7.0",
    "socket.io": "^4.8.3",
